<!DOCTYPE html>
<html lang="hi">
<head>
<%- include('../partials/head', { title: 'लॉगिन - प्राथमिक विद्यालय सहायक' }) %>
</head>
<body>
<div class="center-screen">
    <div class="auth-card">
        <div class="eyebrow">प्राथमिक विद्यालय सहायक</div>
        <h1>लॉगिन करें</h1>
        <div class="desc">विद्यालय का रिकॉर्ड देखने के लिए अपना यूज़रनेम और पासवर्ड डालें।</div>

        <%- include('../partials/messages') %>

        <form method="POST" action="/auth/login">
            <div class="form-grid">
                <div class="field full">
                    <label for="username">यूज़रनेम</label>
                    <input type="text" id="username" name="username" required autofocus>
                </div>
                <div class="field full">
                    <label for="password">पासवर्ड</label>
                    <input type="password" id="password" name="password" required>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">लॉगिन करें</button>
            </div>
        </form>
        <p style="margin-top:18px; font-size:12.5px; color:var(--text-muted);">
            पहली बार उपयोग कर रहे हैं? README.md में दिए निर्देश अनुसार
            <code>node database/createAdmin.js</code> चलाकर डिफ़ॉल्ट लॉगिन बनाएँ
            (username: <b>admin</b>, password: <b>admin123</b>)।
        </p>
    </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
