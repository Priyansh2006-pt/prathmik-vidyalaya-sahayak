<!DOCTYPE html>
<html lang="hi">
<head>
<%- include('../partials/head', { title: 'छात्र प्रबंधन' }) %>
</head>
<body>
<div class="app-shell">
<%- include('../partials/nav', { active: 'students' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <h1>छात्र प्रबंधन</h1>
            <div class="subtitle">कुल <%= students.length %> छात्र दिख रहे हैं</div>
        </div>
        <a href="/students/add" class="btn btn-primary">+ नया छात्र जोड़ें</a>
    </div>

    <%- include('../partials/messages') %>

    <form method="GET" action="/students" class="filter-bar">
        <div class="field">
            <label>कक्षा</label>
            <select name="class_filter" onchange="this.form.submit()">
                <option value="">सभी कक्षाएं</option>
                <% classes.forEach(function(c) { %>
                    <option value="<%= c %>" <%= class_filter === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
            </select>
        </div>
        <div class="field">
            <label>नाम / रोल नंबर खोजें</label>
            <input type="text" name="search" value="<%= search %>" placeholder="जैसे: राम या 15">
        </div>
        <div class="field"><button type="submit" class="btn btn-outline btn-sm">खोजें</button></div>
    </form>

    <div class="card" style="padding:0;">
        <% if (students.length === 0) { %>
            <div class="empty-state">
                <div class="icon">🧒</div>
                कोई छात्र नहीं मिला। <a href="/students/add">पहला छात्र जोड़ें</a>।
            </div>
        <% } else { %>
        <div class="table-wrap">
        <table class="register">
            <thead>
                <tr>
                    <th>रोल नं.</th><th>नाम</th><th>कक्षा</th><th>पिता का नाम</th>
                    <th>लिंग</th><th>अभि. मोबाइल</th><th>क्रियाएं</th>
                </tr>
            </thead>
            <tbody>
                <% students.forEach(function(s) { %>
                <tr>
                    <td><%= s.roll_number %></td>
                    <td><%= s.student_name %></td>
                    <td><%= s.class_name %></td>
                    <td><%= s.father_name %></td>
                    <td><%= s.gender %></td>
                    <td><%= s.guardian_mobile %></td>
                    <td>
                        <a href="/students/edit/<%= s.student_id %>" class="btn btn-outline btn-sm">संपादित करें</a>
                        <form method="POST" action="/students/delete/<%= s.student_id %>" style="display:inline;" onsubmit="return confirm('क्या आप वाकई इस छात्र को हटाना चाहते हैं?');">
                            <button type="submit" class="btn btn-danger btn-sm">हटाएं</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        </div>
        <% } %>
    </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
